{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nickel API Documentation",
  "colors": {
    "primary": "#3A032D",
    "light": "#9B3278",
    "dark": "#3A032D"
  },
  "favicon": "/favicon.ico",
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "api-reference/payments",
          "api-reference/webhooks"
        ]
      },
      {
        "group": "API Reference",
        "openapi": "/nickel-api-docs.yaml"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Nickel",
          "href": "https://nickel.com",
          "icon": "house"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo500.png",
    "dark": "/logo500.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api-support@nickel.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.nickel.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/nickelhq"
    }
  }
}
